{
  "name": "cosmic-remote-kit",
  "version": "0.1.0",
  "description": "Research + prototype kit for remote control of Pop!_OS COSMIC Wayland sessions.",
  "type": "module",
  "scripts": {
    "check": "node ./prototype/cosmic-remote-check.js",
